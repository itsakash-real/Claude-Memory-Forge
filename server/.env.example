# ══════════════════════════════════════════════════════════════
#  Claude Memory Forge — Server Environment Variables
#  Copy this file to .env and fill in values
# ══════════════════════════════════════════════════════════════

# ─── Gemini API Keys (required) ──────────────────────────────
# Get free keys from: https://aistudio.google.com/apikey
# Two keys = hybrid round-robin + failover rotation
GEMINI_KEY_1=AIzaSyBamheDUZXX-uR2fwWYomabnCcQ8IW5KBI
GEMINI_KEY_2=AIzaSyAhFvmWVRCBJgqzx1pdBusQDFOKrNJBmts

# ─── Redis for BullMQ Job Queue (required for production) ────
# Local dev: redis://localhost:6379
# Production: Get a managed Redis from Railway, Render, or Upstash
REDIS_URL=redis://localhost:6379

# ─── Upstash Redis for Rate Limiting (optional but recommended) ──
# Free tier: https://console.upstash.com
# If not set, rate limiting is skipped (dev-only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production